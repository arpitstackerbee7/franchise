 "html": "<style>\n     \n    .print-format {\n        /*background-image: url(\"http://tejoo.localhost:8000/files/cheque1.jpeg\");*/\n        background-size: 20.3cm 9.3cm;\n        background-repeat: no-repeat;\n        /*height: 9.3cm;*/\n        /*width: 20.3cm;*/\n        width:203mm;\n        height:95mm;\n        padding: 0 !important;\n    } \n    \n\n    .cheque-wrapper {\n        position: relative;\n        width: 20.3cm;\n        height: 9.3cm;\n        font-family: Arial, sans-serif;\n        font-weight: bold;\n        color: #000;\n    }\n\n    /* 1. Account Payee Stamp */\n    .ac-payee {\n        position: absolute;\n        top: 2.0cm;\n        left: 12.6cm;\n        border-top: 1.2px solid #000;\n        border-bottom: 1.2px solid #000;\n        padding: 0px 5px;\n        font-size: 11px;\n    }\n\n    /* 2. Date Section - Positioned inside the date boxes */\n    .date-container {\n        position: absolute;\n            top: 1.35cm;\n    left: 19.2cm;\n\n        text-wrap: nowrap;\n        letter-spacing: 0.52cm; \n    }\n    .date-char {\n        display: inline-block;\n        width: 0.49cm;\n        text-align: center;\n        font-size: 15px; \n    }\n\n    /* 3. Payee Name - Positioned on the first line after 'Pay' */\n    .payee-name {\n        position: absolute;\n        top: 2.6cm;\n    left: 5.5cm;\n    font-size: 13px;\n    width: 18cm;\n    }\n\n    /* 4. Amount in Words - Positioned on the second line after 'Rupees' */\n    .amount-words {\n        position: absolute;\n        top: 3.4cm;\n        left: 6.7cm;        \n        width: 12.5cm;\n        line-height: 0.7cm;\n        font-size: 13px; \n    }\n\n    /* 5. Amount in Figures - Positioned inside the amount box */\n    .amount-figures {\n        position: absolute;\n                top: 4.1cm;\n    left: 19.4cm;\n    text-wrap: nowrap;\n\n        font-size: 17px; \n        width: 3.5cm;\n    }\n\n    /* 6. Account Number Box - Positioned in the dashed box on the left */\n    .acc-no-box {\n        position: absolute;\n        top: 4.99cm;\n        left: 3.6cm;\n        font-size: 14px;\n    }\n\n    /* 7. Signatory Section - Positioned above Authorised Signatories */\n    .signatory {\n        position: absolute;\n        top: 5.00cm; \n        left: 14.00cm;\n        width: 6.0cm;\n        text-align: center;\n        font-size: 12px;\n    }\n</style>\n\n<div class=\"cheque-wrapper\">\n    <!-- A/C PAYEE STAMP -->\n    <!--<div class=\"ac-payee\">A/C PAYEE</div>-->\n    \n    <!-- DATE SECTION (DDMMYYYY) -->\n    <div class=\"date-container\">\n        {% if doc.reference_date %}\n            {% set d = frappe.utils.getdate(doc.reference_date).strftime('%d%m%Y') %}\n            {% for char in d %}<span class=\"date-char\">{{ char }}</span>{% endfor %}\n        {% endif %}\n    </div>\n\n    <!-- PAYEE NAME -->\n    <div class=\"payee-name\">{{ doc.party_name }}</div>\n\n    <!-- AMOUNT IN WORDS (Formatted to remove currency code) -->\n    <div class=\"amount-words\">\n        {{ frappe.utils.money_in_words(doc.base_paid_amount or doc.base_received_amount).replace('INR ', '').replace('Only.', 'Only') }}\n    </div>\n\n    <!-- AMOUNT IN FIGURES -->\n    <div class=\"amount-figures\">\n        {{ doc.get_formatted(\"base_paid_amount\").replace(\"\u20b9\", \"\").replace(\"Rs.\", \"\").replace(\".00\", \"\") or doc.get_formatted(\"base_received_amount\").replace(\"\u20b9\", \"\").replace(\"Rs.\", \"\").replace(\".00\", \"\") }} /-\n    </div>\n\n    <!-- ACCOUNT NUMBER -->\n    <!--<div class=\"acc-no-box\">{{ doc.account_no or '777705500334' }}</div>-->\n\n    <!-- COMPANY NAME FOR SIGNATURE -->\n    <!--<div class=\"signatory\">{{ doc.company }}</div>-->\n</div>",
